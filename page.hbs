{{!< default}}

<main class="site">

    <header class="site-header">
        <h1 class="site-title"><a href="{{@site.url}}">{{@site.title}}</a></h1>
    </header>

    {{#page}}
    <article class="post-content">
        <h2 class="post-title">{{title}}</h2>
        <div class="post-body">{{content}}</div>
    </article>

    <nav class="post-nav">
        <a href="{{@site.url}}">← All writing</a>
    </nav>
    {{/page}}

</main>
