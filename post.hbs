{{!< default}}

<main class="site">

    <header class="site-header">
        <h1 class="site-title"><a href="{{@site.url}}">{{@site.title}}</a></h1>
    </header>

    {{#post}}
    <article class="post-content">
        <h2 class="post-title">{{title}}</h2>
        <div class="post-meta">{{date published_at format="MMMM D, YYYY"}}</div>
        {{#if feature_image}}
        <div class="post-feature-image">
            <img src="{{feature_image}}" alt="{{#if feature_image_alt}}{{feature_image_alt}}{{else}}{{title}}{{/if}}">
        </div>
        {{/if}}
        <div class="post-body">{{content}}</div>
    </article>

    <nav class="post-nav">
        <a href="{{@site.url}}">← All writing</a>
    </nav>
    {{/post}}

</main>
